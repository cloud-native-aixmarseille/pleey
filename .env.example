# Environment variables example file
# Copy this file to .env and modify the values

# Database (PostgreSQL)
DATABASE_URL=postgresql://quizapp:quizapp_password@postgres:5432/quizdb?schema=public
DATABASE_URL_TEST=postgresql://quizapp:quizapp_password@postgres:5432/quizdb_test?schema=public
POSTGRES_DB=quizdb
POSTGRES_PASSWORD=quizapp_password
POSTGRES_TEST_DB=quizdb_test
POSTGRES_USER=quizapp

# Access token expiration in seconds (default: 3600 = 1 hour)
JWT_ACCESS_EXPIRES_IN_SECONDS=3600
# Refresh token expiration in seconds (default: 1209600 = 14 days)
JWT_REFRESH_EXPIRES_IN_SECONDS=1209600
# Refresh token configuration
# Optional: override to use a different secret for refresh tokens
JWT_REFRESH_SECRET=
# JWT Secret - CHANGE THIS VALUE IN PRODUCTION
JWT_SECRET=your_super_secure_jwt_secret_change_me_in_production

# CORS Origin - Define allowed origins for requests
# Development with Traefik: http://pleey.localhost
# Production: your domain or * to allow all (not recommended)
CORS_ORIGIN=*

# Ports (used in production only - dev uses Traefik)
BACKEND_PORT=3001
FRONTEND_PORT=80

# Node Environment
NODE_ENV=production

# Frontend API URL (used by Vite)
# Optional. Leave empty to infer API from the current browser URL (recommended with Traefik).
# If you set it, use a browser-reachable URL (not a Docker-only hostname like http://backend:3001).
VITE_API_URL=
