# Fichier d'exemple des variables d'environnement
# Copier ce fichier en .env et modifier les valeurs

# Database (PostgreSQL)
POSTGRES_USER=quizapp
POSTGRES_PASSWORD=quizapp_password
POSTGRES_DB=quizdb
DATABASE_URL="postgresql://quizapp:quizapp_password@postgres:5432/quizdb?schema=public"

# JWT Secret - CHANGEZ CETTE VALEUR EN PRODUCTION
JWT_SECRET=votre_secret_jwt_super_securise_changez_moi_en_production

# CORS Origin - Définir les origines autorisées pour les requêtes
# En développement: http://localhost:5173
# En production: votre domaine ou * pour tout autoriser (non recommandé)
CORS_ORIGIN=*

# Ports
BACKEND_PORT=3001
FRONTEND_PORT=80

# Node Environment
NODE_ENV=production

# Frontend API URL (utilisé par Vite)
VITE_API_URL=http://localhost:3001