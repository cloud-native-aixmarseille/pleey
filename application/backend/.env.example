# Database
DATABASE_URL=postgresql://quizuser:quizpass@localhost:5432/quizdb?schema=public

# Integration tests (Vitest e2e) MUST use a different database than dev.
DATABASE_URL_TEST=postgresql://quizuser:quizpass@localhost:5432/quizdb_test?schema=public

# JWT
JWT_EXPIRATION=24h
JWT_SECRET=your_jwt_secret_change_me

# Server
NODE_ENV=development
PORT=3001

# CORS
CORS_ORIGIN=*

# OpenTelemetry (Optional - console exporters and console log mirroring are disabled by default)
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# OTEL_EXPORTER_OTLP_HEADERS='{"Authorization":"Bearer YOUR_TOKEN"}'
# OTEL_CONSOLE_DIAGNOSTICS_ENABLED=false
# OTEL_CONSOLE_EXPORTERS_ENABLED=false
# OTEL_CONSOLE_LOGS_ENABLED=false
