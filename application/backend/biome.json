{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "src/**",
      "test/**",
      "prisma/**",
      "prisma.config.ts",
      "vitest.config.ts",
      "vitest.config.mts"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "includes": ["**", "!src/schema.gql"],
    "rules": {
      "recommended": true,
      "style": {
        "noProcessEnv": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "**/app/config",
                  "**/app/config/**",
                  "src/app/config",
                  "src/app/config/**"
                ],
                "message": "Only the app layer may import app config readers. Inject derived configuration values into other layers via providers."
              }
            ]
          }
        },
        "useImportType": "off",
        "useConst": "error",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": {
          "level": "error",
          "options": {
            "ignoreRestSiblings": true
          }
        },
        "noUnusedFunctionParameters": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "includes": ["**", "!src/schema.gql"],
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "overrides": [
    {
      "includes": ["src/app/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/app/config/**/*.ts",
        "src/domain/**/services/*identifier.ts",
        "src/**/*.spec.ts",
        "src/**/*.int.spec.ts",
        "test/**/*.ts",
        "prisma/**/*.ts",
        "prisma.config.ts",
        "vitest.config.ts",
        "vitest.config.mts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          },
          "complexity": {
            "noStaticOnlyClass": "off"
          }
        }
      }
    },
    {
      "includes": ["src/application/**/*.ts", "src/domain/**/*.ts"],
      "plugins": ["./biome/plugins/application-domain-boundaries.grit"]
    },
    {
      "includes": ["src/application/**/*.ts", "src/domain/**/*.ts", "src/infrastructure/**/*.ts"],
      "plugins": ["./biome/plugins/identifier-boundaries.grit"]
    },
    {
      "includes": ["src/presentation/**/*.ts"],
      "plugins": ["./biome/plugins/presentation-boundaries.grit"]
    },
    {
      "includes": ["src/domain/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@nestjs/common"],
                    "importNamePattern": "Exception",
                    "message": "Domain layer must not import NestJS exceptions. Throw domain errors and translate them in the application/presentation layer."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/application/**/use-cases/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@nestjs/common"],
                    "importNamePattern": "Exception",
                    "message": "Use cases must not import framework-specific exceptions. Throw ApplicationError/domain errors and map them in infrastructure filters."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/application/workspace/dashboard/**/*.ts"],
      "plugins": ["./biome/plugins/dashboard-application-boundaries.grit"]
    }
  ]
}
