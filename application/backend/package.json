{
  "name": "quiz-backend",
  "version": "0.0.1",
  "description": "Pleey backend",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "lint": "node ./scripts/check-naming.mjs && node ./scripts/check-di-instantiation.mjs && node ./scripts/check-game-refactor-boundaries.mjs && npm run lint:unused-exports && npm run lint:knip && biome lint --error-on-warnings .",
    "lint:fix": "node ./scripts/check-naming.mjs && node ./scripts/check-di-instantiation.mjs && node ./scripts/check-game-refactor-boundaries.mjs && npm run lint:unused-exports && npm run lint:knip && biome check --error-on-warnings --write .",
    "lint:ci": "node ./scripts/check-naming.mjs && node ./scripts/check-di-instantiation.mjs && node ./scripts/check-game-refactor-boundaries.mjs && npm run lint:unused-exports && npm run lint:knip && biome ci --error-on-warnings .",
    "lint:knip": "knip --config knip.json",
    "lint:unused-exports": "node ./scripts/find-unused-exports.mjs ./src",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/app/main",
    "seed": "ts-node --esm --transpile-only prisma/seed.ts",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "npm run db:migrate && npm run db:generate && npm run seed",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest --config ./test/vitest.config.e2e.ts",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@dicebear/collection": "^9.2.4",
    "@dicebear/core": "^9.2.4",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/platform-socket.io": "^11.1.11",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.1.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.208.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-logs-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.6",
    "nestjs-i18n": "^10.6.0",
    "nestjs-otel": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^7.8.0",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.11",
    "@prisma/config": "^7.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.15",
    "knip": "^6.9.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.8"
  },
  "_comment": "The 'prisma' section is required for Prisma 6.x seed functionality. While deprecated, it's the only supported method until Prisma 7. See: https://pris.ly/prisma-config",
  "prisma": {
    "seed": "ts-node --esm --transpile-only prisma/seed.ts"
  }
}
