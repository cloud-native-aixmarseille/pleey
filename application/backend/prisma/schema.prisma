// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  avatarMediaId Int? @unique @map("avatar_media_id")
  refreshTokenHash String? @map("refresh_token_hash")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  avatar              Media? @relation("UserAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)
  scores              Score[]
  hostedParties       Party[] @relation("HostedParties")
  organizationMembers OrganizationMember[]
  
  @@map("users")
}

model Media {
  id        Int      @id @default(autoincrement())
  mimeType  String   @map("mime_type")
  content   Bytes
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  avatarForUser User? @relation("UserAvatar")

  @@map("media")
}

model Game {
  id             Int      @id @default(autoincrement())
  type           String
  title          String
  description    String?
  projectId      Int      @map("project_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  project    Project @relation(fields: [projectId], references: [id])
  quiz       Quiz?
  prediction Prediction?
  parties    Party[]

  @@map("games")
}

model Party {
  id              Int      @id @default(autoincrement())
  gameId          Int      @map("game_id")
  hostId          Int      @map("host_id")
  pin             String   @unique
  status          String   @default("waiting")
  context         Json?    @map("context")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  game   Game  @relation(fields: [gameId], references: [id])
  host   User  @relation("HostedParties", fields: [hostId], references: [id])
  scores Score[]

  @@map("parties")
}

model Guest {
  id         String   @id @default(cuid())
  username   String
  avatarSeed String   @map("avatar_seed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  scores Score[]

  @@map("guests")
}

model Score {
  id         Int      @id @default(autoincrement())
  partyId    Int      @map("party_id")
  userId     Int?     @map("user_id")
  guestId    String?  @map("guest_id")
  context    Json?    @map("context")
  points     Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  party    Party  @relation(fields: [partyId], references: [id])
  user     User?  @relation(fields: [userId], references: [id])
  guest    Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@map("scores")
}

model Organization {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  members OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model OrganizationMember {
  id             Int      @id @default(autoincrement())
  organizationId Int      @map("organization_id")
  userId         Int      @map("user_id")
  role           String   @default("member") // owner, manager, member
  createdAt      DateTime @default(now()) @map("created_at")
  joinedAt       DateTime @default(now()) @map("joined_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Project {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  organizationId Int      @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  games        Game[]

  @@map("projects")
}

model Quiz {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  game          Game     @relation(fields: [gameId], references: [id])
  gameId        Int      @unique @map("game_id")

  questions    Question[]

  @@map("quizzes")
}

model Question {
  id           Int      @id @default(autoincrement())
  quizId       Int      @map("quiz_id")
  position     Int      @map("position")
  questionText String   @map("question_text")
  type         String   // 'multiple' or 'truefalse'
  timeLimit    Int      @default(20) @map("time_limit")
  points       Int      @default(1000)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  quiz          Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       QuestionAnswer[] @relation("QuestionAnswers")

  @@unique([quizId, position])
  @@map("questions")
}

model QuestionAnswer {
  id         Int     @id @default(autoincrement())
  questionId Int     @map("question_id")
  text       String? @map("answer_text")
  position   Int     @default(0) @map("position")
  isCorrect  Boolean @default(false) @map("is_correct")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  question   Question @relation("QuestionAnswers", fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, position])
  @@map("question_answers")
}

model Prediction {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  game          Game     @relation(fields: [gameId], references: [id])
  gameId        Int      @unique @map("game_id")

  prompts       PredictionPrompt[]

  @@map("predictions")
}

model PredictionPrompt {
  id            Int      @id @default(autoincrement())
  predictionId  Int      @map("prediction_id")
  position      Int      @map("position")
  promptText    String   @map("prompt_text")
  timeLimit     Int      @default(20) @map("time_limit")
  points        Int      @default(1000)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  prediction    Prediction        @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  options       PredictionOption[] @relation("PredictionOptions")

  @@unique([predictionId, position])
  @@map("prediction_prompts")
}

model PredictionOption {
  id           Int     @id @default(autoincrement())
  promptId     Int     @map("prompt_id")
  text         String? @map("option_text")
  position     Int     @default(0) @map("position")
  isCorrect    Boolean @default(false) @map("is_correct")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  prompt       PredictionPrompt @relation("PredictionOptions", fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, position])
  @@map("prediction_options")
}
