{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "includes": [
      "src/**",
      "!!**/src/infrastructure/graphql/generated",
      "codegen.ts",
      "vite.config.js",
      "vitest.config.js",
      "tailwind.config.js",
      "postcss.config.js"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "warn"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": {
          "level": "warn",
          "options": {
            "ignoreRestSiblings": true
          }
        },
        "noUnusedFunctionParameters": "off"
      },
      "style": {
        "useImportType": "off",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["src/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/app/**/errors/*error-code",
                      "**/app/**/errors/*error-code.*",
                      "**/application/**/errors/*error-code",
                      "**/application/**/errors/*error-code.*",
                      "**/presentation/**/errors/*error-code",
                      "**/presentation/**/errors/*error-code.*",
                      "**/infrastructure/**/errors/*error-code",
                      "**/infrastructure/**/errors/*error-code.*",
                      "src/app/**/errors/*error-code",
                      "src/app/**/errors/*error-code.*",
                      "src/application/**/errors/*error-code",
                      "src/application/**/errors/*error-code.*",
                      "src/presentation/**/errors/*error-code",
                      "src/presentation/**/errors/*error-code.*",
                      "src/infrastructure/**/errors/*error-code",
                      "src/infrastructure/**/errors/*error-code.*"
                    ],
                    "message": "Error-code modules must live under src/domains/**/errors. Import domain-owned error codes instead of defining or consuming them from app, application, presentation, or infrastructure layers."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/application/**/*.{ts,tsx,js,jsx}",
        "src/domains/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/infrastructure",
                      "**/infrastructure/**",
                      "src/infrastructure",
                      "src/infrastructure/**"
                    ],
                    "message": "Application and domain layers cannot import from infrastructure layer. Depend on contracts and bind concrete adapters at the composition boundary."
                  },
                  {
                    "group": [
                      "**/presentation",
                      "**/presentation/**",
                      "src/presentation",
                      "src/presentation/**"
                    ],
                    "message": "Application and domain layers cannot import from presentation layer. Keep UI concerns outside these layers."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/application/workspace/dashboard/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/app", "**/app/**", "src/app", "src/app/**"],
                    "message": "Dashboard application code must not import from app composition. Depend on dashboard-owned contracts and bind implementations in app/container modules instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/application/game-session/live/host/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/application/game-session/live/player/**",
                      "src/application/game-session/live/player/**",
                      "**/application/game/use-cases/**",
                      "src/application/game/use-cases/**"
                    ],
                    "message": "Live host application code must not depend on live player or legacy game use-case paths. Share behavior through game-session/live/shared services or domain/application contracts instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/application/game-session/live/player/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/application/game-session/live/host/**",
                      "src/application/game-session/live/host/**",
                      "**/application/game/use-cases/**",
                      "src/application/game/use-cases/**"
                    ],
                    "message": "Live player application code must not depend on live host or legacy game use-case paths. Share behavior through game-session/live/shared services or domain/application contracts instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/presentation/**/*.{ts,tsx,js,jsx}",
        "!!src/presentation/**/routes/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/application/**/services",
                      "**/application/**/services/**",
                      "src/application/**/services",
                      "src/application/**/services/**"
                    ],
                    "message": "Presentation components, hooks, and screens must not import application services directly. Inject route/service collaborators from route factories or app providers instead of instantiating services in presentation code."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/presentation/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["react"],
                    "importNamePattern": "CSSProperties",
                    "message": "Presentation styles must be defined in src/presentation/shared/ui/foundation/ui-theme.ts. Do not type local style objects with React CSSProperties outside the theme foundation."
                  },
                  {
                    "group": ["@mantine/*"],
                    "message": "Presentation code must not import Mantine directly. Use components from src/presentation/shared/ui instead."
                  },
                  {
                    "group": [
                      "**/infrastructure",
                      "**/infrastructure/**",
                      "src/infrastructure",
                      "src/infrastructure/**"
                    ],
                    "message": "Presentation layer cannot import from infrastructure layer. Consume application/domain abstractions instead."
                  },
                  {
                    "group": ["**/app", "**/app/**", "src/app", "src/app/**"],
                    "message": "Presentation layer cannot import from app layer. App is the composition boundary and may depend on presentation, not the reverse."
                  },
                  {
                    "group": [
                      "**/domains/**/services",
                      "**/domains/**/services/**",
                      "src/domains/**/services",
                      "src/domains/**/services/**",
                      "**/application/**/use-cases",
                      "**/application/**/use-cases/**",
                      "src/application/**/use-cases",
                      "src/application/**/use-cases/**"
                    ],
                    "message": "Presentation layer must not import domain services or application use-cases directly. Use dependency injection through service context providers instead."
                  },
                  {
                    "group": [
                      "react-router-dom",
                      "react-i18next",
                      "@tanstack/react-form"
                    ],
                    "message": "Presentation layer must consume routing and translation through presentation hooks/components backed by existing-layer adapters instead of importing framework packages directly."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/presentation/shared/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["react"],
                    "importNamePattern": "CSSProperties",
                    "message": "Shared presentation styles must be defined in src/presentation/shared/ui/foundation/ui-theme.ts. Do not type local style objects with React CSSProperties outside the theme foundation."
                  },
                  {
                    "group": [
                      "**/infrastructure",
                      "**/infrastructure/**",
                      "src/infrastructure",
                      "src/infrastructure/**"
                    ],
                    "message": "Presentation layer cannot import from infrastructure layer. Consume application/domain abstractions instead."
                  },
                  {
                    "group": ["**/app", "**/app/**", "src/app", "src/app/**"],
                    "message": "Presentation layer cannot import from app layer. App is the composition boundary and may depend on presentation, not the reverse."
                  },
                  {
                    "group": [
                      "react-router-dom",
                      "react-i18next",
                      "@tanstack/react-form"
                    ],
                    "message": "Presentation layer must consume routing and translation through presentation hooks/components backed by existing-layer adapters instead of importing framework packages directly."
                  }
                ]
              }
            }
          },
          "a11y": {
            "noAutofocus": "error",
            "noNoninteractiveTabindex": "error",
            "noPositiveTabindex": "error",
            "noStaticElementInteractions": "error",
            "useAriaPropsForRole": "error",
            "useButtonType": "error",
            "useFocusableInteractive": "error",
            "useKeyWithClickEvents": "error",
            "useKeyWithMouseEvents": "error",
            "useSemanticElements": "error",
            "useValidAriaProps": "error",
            "useValidAriaRole": "error"
          }
        }
      }
    },
    {
      "includes": ["src/presentation/game-session/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/presentation/shared/ui/foundation/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["src/domains/game/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "src/domains/quiz",
                      "src/domains/quiz/**",
                      "src/domains/prediction",
                      "src/domains/prediction/**",
                      "src/application/quiz-management",
                      "src/application/quiz-management/**",
                      "src/application/prediction-management",
                      "src/application/prediction-management/**",
                      "src/infrastructure/quiz",
                      "src/infrastructure/quiz/**",
                      "src/infrastructure/prediction",
                      "src/infrastructure/prediction/**",
                      "src/presentation/quiz",
                      "src/presentation/quiz/**",
                      "src/presentation/prediction",
                      "src/presentation/prediction/**"
                    ],
                    "message": "Generic game domain code must stay agnostic from quiz and prediction modules. Depend on neutral game contracts only."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/application/game/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "src/application/quiz-management",
                      "src/application/quiz-management/**",
                      "src/application/prediction-management",
                      "src/application/prediction-management/**",
                      "src/domains/quiz",
                      "src/domains/quiz/**",
                      "src/domains/prediction",
                      "src/domains/prediction/**",
                      "src/infrastructure/quiz",
                      "src/infrastructure/quiz/**",
                      "src/infrastructure/prediction",
                      "src/infrastructure/prediction/**",
                      "src/presentation/quiz",
                      "src/presentation/quiz/**",
                      "src/presentation/prediction",
                      "src/presentation/prediction/**"
                    ],
                    "message": "Generic game application code must stay agnostic from concrete quiz and prediction modules."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/presentation/game/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "src/domains/quiz",
                      "src/domains/quiz/**",
                      "src/domains/prediction",
                      "src/domains/prediction/**",
                      "src/application/quiz-management",
                      "src/application/quiz-management/**",
                      "src/application/prediction-management",
                      "src/application/prediction-management/**",
                      "src/infrastructure/quiz",
                      "src/infrastructure/quiz/**",
                      "src/infrastructure/prediction",
                      "src/infrastructure/prediction/**",
                      "src/presentation/quiz",
                      "src/presentation/quiz/**",
                      "src/presentation/prediction",
                      "src/presentation/prediction/**"
                    ],
                    "message": "Generic game presentation code must not depend on concrete quiz or prediction modules."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/application/**/use-cases/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "../ports",
                      "../ports/**",
                      "../../ports",
                      "../../ports/**",
                      "**/application/**/ports",
                      "**/application/**/ports/**",
                      "src/application/**/ports",
                      "src/application/**/ports/**"
                    ],
                    "message": "Application use-cases must not import application-layer ports."
                  },
                  {
                    "group": [
                      "../services",
                      "../services/**",
                      "../../services",
                      "../../services/**",
                      "**/application/**/services",
                      "**/application/**/services/**",
                      "src/application/**/services",
                      "src/application/**/services/**"
                    ],
                    "message": "Application use-cases must not import application-layer services."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
