{
  "overrides": [
    {
      "includes": ["src/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/game/party/*/**",
                      "!**/game/party/enums/**",
                      "!**/game/party/errors/**",
                      "!**/game/party/host/**",
                      "!**/game/party/player/**",
                      "!**/game/party/shared/**"
                    ],
                    "message": "Only **/game/party/{host,player,shared}/** is allowed under game/party."
                  }
                ]
              }
            }
          }
        }
      }
    },
    { 
      "includes": ["src/presentation/game/types/shared/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/game/types/quiz/**", "**/game/types/prediction/**"],
                    "message": "Game types shared layer must not import from game-type specific layers (quiz/, prediction/)."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/presentation/game/party/shared/**/*.{ts,tsx,js,jsx}",
        "!!src/presentation/game/party/shared/screens/components/party-screen-content.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/game/party/host/**", "**/game/party/player/**"],
                    "message": "Party shared layer must not import from host/ or player/ layers. Shared must stay role-agnostic."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
