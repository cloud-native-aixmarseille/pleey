{
  "name": "quiz-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "lint:ci": "npm run lint -- --format json -o eslint-report.json",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "openapi:generate": "openapi-typescript http://backend:3001/api/openapi.json --output src/infrastructure/shared/http/api/openapi-schema.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.16",
    "i18next": "^25.7.3",
    "lucide-react": "^0.562.0",
    "openapi-react-query": "^0.5.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.1",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.12.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.1.17",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.15",
    "vitest-axe": "^0.1.0"
  }
}
