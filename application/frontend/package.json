{
  "name": "pleey-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "lint": "node ./scripts/check-presentation-screens.mjs && node ./scripts/check-naming.mjs && node ./scripts/check-di-instantiation.mjs && npm run typecheck && biome lint --error-on-warnings .",
    "lint:fix": "node ./scripts/check-presentation-screens.mjs && node ./scripts/check-naming.mjs && node ./scripts/check-di-instantiation.mjs && biome check --write . && npm run typecheck",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/client": "^4.1.5",
    "@mantine/core": "^8.3.17",
    "@mantine/hooks": "^8.3.17",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-form": "^1.28.5",
    "framer-motion": "^11.18.2",
    "graphql": "^16.12.0",
    "i18next": "^25.7.3",
    "inversify": "^7.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.1",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.12.0",
    "reflect-metadata": "^0.2.2",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "typescript": "^5.7.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  }
}
